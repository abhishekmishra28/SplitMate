# Shared Expenses App — Root .gitignore

# Node modules — never commit these
node_modules/

# Environment files — contain secrets
.env
.env.local
.env.production

# Build outputs
client/dist/
client/build/

# Prisma generated client
server/node_modules/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Multer temp uploads
server/uploads/

# Editor config
.vscode/
.idea/
*.swp
*.swo

# Coverage
coverage/

# Prisma
server/prisma/migrations/dev.db
